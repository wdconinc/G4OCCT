<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>G4OCCT — Point Cloud Viewer</title>
  <style>
{{ css_content }}
  </style>
  <script type="importmap">
  {"imports":{
    "three":"https://cdn.jsdelivr.net/npm/three@0.169.0/build/three.module.js",
    "three/addons/":"https://cdn.jsdelivr.net/npm/three@0.169.0/examples/jsm/"
  }}
  </script>
</head>
<body>
  <div id="header">
    <h1>G4OCCT — Geantino Ray Point Cloud</h1>
    <span class="meta">Generated: {{ timestamp }} · {{ count_str }}</span>
  </div>
  <div id="main">
    <div id="sidebar">
      <div id="sidebar-inner">
        <label for="fixture-select">Fixture</label>
        <select id="fixture-select"></select>
        <div class="toggle-row">
          <button id="btn-native" class="toggle-btn native">Native</button>
          <button id="btn-imported" class="toggle-btn imported">Imported</button>
        </div>
        <div class="view-row">
          <button id="btn-view-x" class="view-btn" title="View from X axis — click again to flip direction">X</button>
          <button id="btn-view-y" class="view-btn" title="View from Y axis — click again to flip direction">Y</button>
          <button id="btn-view-z" class="view-btn" title="View from Z axis — click again to flip direction">Z</button>
          <button id="btn-grid" class="view-btn" title="Toggle coordinate grid planes">Grid</button>
          <button id="btn-ortho" class="view-btn" title="Toggle orthographic projection">Persp</button>
        </div>
        <div class="offset-row">
          <label for="offset-slider">Imported offset: <span id="offset-value"></span></label>
          <input id="offset-slider" type="range" min="0" max="5" step="0.1" value="1">
        </div>
        <table class="stats-table"><tbody id="stats-body"></tbody></table>
        <div class="legend">
          <div class="legend-item"><span class="legend-dot native"></span>Native</div>
          <div class="legend-item"><span class="legend-dot imported"></span>Imported</div>
        </div>
        <div id="empty-msg">No point-cloud data found.</div>
      </div>
    </div>
    <div id="canvas-container">
      <button id="sidebar-toggle" title="Hide sidebar" aria-label="Hide sidebar" aria-expanded="true">◀</button>
      <div id="grid-spacing-overlay"></div>
      <div id="count-overlay"></div>
      <div id="info-overlay">drag to rotate · scroll to zoom · right-drag to pan</div>
    </div>
  </div>
  <script type="application/json" id="fixture-data">{{ fixture_json }}</script>
  <script type="module">
{{ js_content }}
  </script>
</body>
</html>
