# G4OCCTConfig.cmake
# CMake package configuration file for G4OCCT.
# Downstream projects use this via:
#   find_package(G4OCCT REQUIRED)
#   target_link_libraries(myTarget PRIVATE G4OCCT::G4OCCT)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Geant4 REQUIRED)
find_dependency(OpenCASCADE REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/G4OCCTTargets.cmake")

check_required_components(G4OCCT)
